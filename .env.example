# ==============================================================================
# CS2 OBSERVER BOT - CONFIGURATION DES CLÉS API & RÉSEAU
# ==============================================================================

# Clé API CSFloat (requis pour le tracking et l'historique CSFloat)
CSFLOAT_API_KEY=

# Clés API DMarket (requis pour la signature Ed25519 de DMarket)
DMARKET_PUBLIC_KEY=
DMARKET_SECRET_KEY=

# Clé API Market.CSGO (requis pour charger le dictionnaire et s'abonner au WebSocket)
MARKET_CSGO_API_KEY=

# Clé API Waxpeer (requis pour s'abonner au WebSocket Waxpeer)
WAXPEER_API_KEY=

# ==============================================================================
# PARAMÈTRES DE CONTRÔLE DE L'OBSERVATION
# ==============================================================================

# Seuils de prix des skins à surveiller (en USD)
MIN_PRICE_USD=10.0
MAX_PRICE_USD=150.0

# Seuil de polling de l'ingestion en millisecondes (par défaut : 1500ms)
# Augmentez la valeur (ex: 2000) si vous subissez des rate limits (HTTP 429)
OBS_POLL_INTERVAL_MS=1500

# Seuil maximal de TTD (Time To Drain) pour conserver les listings observés (en secondes)
# Par défaut : 86400 (24 heures)
OBSERVER_MAX_TTD_SEC=86400
